# JomKecek environment variables
# Copy this file to .env and fill in values before running.
# The app works with defaults — only change what you need.

# --- Ollama LLM ---
# Main chatbot model. Pull it first: ollama pull malaysian-qwen2.5:7b
JOMKECEK_MODEL=malaysian-qwen2.5:7b
# GGUF source: mradermacher/Malaysian-Qwen2.5-7B-Instruct-GGUF (Q4_K_M)
# Modelfile: see ./Modelfile in project root

# Judge model for LLM-as-judge evaluation. Pull: ollama pull qwen2.5:3b
JOMKECEK_JUDGE_MODEL=qwen2.5:3b

# Ollama server URL (default: local)
OLLAMA_URL=http://127.0.0.1:11434

# --- ChromaDB hybrid retrieval ---
# Set to 1 AFTER running: python setup_chroma.py
JOMKECEK_USE_CHROMA=1

# Where to store the vector index
JOMKECEK_CHROMA_PATH=./chroma_db_jomkecek

# Sentence-transformer model used for embedding (multilingual, ~120 MB)
JOMKECEK_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Frontend (Next.js) ---
# Local: http://127.0.0.1:8000
# Demo via ngrok: https://xxxx-xxxx.ngrok-free.app
# Production: set this in Vercel dashboard -> Settings -> Environment Variables
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- CORS (Backend) ---
# Add Vercel frontend URL here so backend accepts requests from it
# Example: https://jomkecek.vercel.app
CORS_ORIGIN=https://jomkecek.vercel.app
